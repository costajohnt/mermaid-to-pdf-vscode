{
  "name": "markdown-mermaid-converter-cli",
  "description": "CLI tool to convert Markdown files with Mermaid diagrams to various formats (PDF, etc.)",
  "version": "1.0.0",
  "author": "Markdown Mermaid Converter Team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/costajohnt/markdown-mermaid-converter.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli.js"
  },
  "bin": {
    "markdown-mermaid-converter": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/vendor dist/vendor",
    "postinstall": "mkdir -p src/vendor && cp node_modules/mermaid/dist/mermaid.min.js src/vendor/mermaid.min.js",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "npm run build && node --test dist/cli.test.js dist/diagramCache.test.js dist/mermaidRenderer.test.js dist/converter.test.js dist/types.test.js",
    "test:e2e": "npm run build && node --test dist/e2e.test.js",
    "test:all": "npm run build && node --test dist/cli.test.js dist/diagramCache.test.js dist/mermaidRenderer.test.js dist/converter.test.js dist/types.test.js dist/e2e.test.js && cd mermaid-to-pdf-mcp && npm test",
    "lint": "eslint src/ mermaid-to-pdf-mcp/src/"
  },
  "keywords": [
    "markdown",
    "mermaid",
    "converter",
    "cli",
    "pdf",
    "diagrams",
    "documentation",
    "format-conversion"
  ],
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "tsx": "^4.0.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "marked": "^12.0.0",
    "mermaid": "^11.12.3",
    "puppeteer": "^23.0.2"
  }
}
